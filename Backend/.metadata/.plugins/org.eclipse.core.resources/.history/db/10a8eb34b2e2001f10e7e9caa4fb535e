package klu.model;

import klu.repository.UsersRepository;

public class UsersManager {
	
UsersRepository UR;
	public String addUser(Users U) {    
	    if(UR.validateEmail(U.getEmail()) > 0)
	      return "Email already exist";    
	    UR.save(U);
	    return "User Registered Successfully";
	  
	  }

}
